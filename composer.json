{
	"name": "detain/myadmin-patchman-licensing",
	"type": "myadmin-plugin",
	"description": "PatchMan Licensing integration for the MyAdmin control panel. Provides license provisioning, activation, deactivation, and IP management for PatchMan security scanning services.",
	"keywords": [
		"patchman",
		"administration",
		"license",
		"myadmin",
		"security"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"ext-curl": "*",
		"symfony/event-dispatcher": "^5.0||^6.0||^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminPatchman\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminPatchman\\Tests\\": "tests/"
		}
	}
}
